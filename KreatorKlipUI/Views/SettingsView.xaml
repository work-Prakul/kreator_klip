<Page
    x:Class="KreatorKlipUI.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <StackPanel Padding="40" Spacing="24" MaxWidth="800" HorizontalAlignment="Left">
        
        <!-- Hardware Diagnostics -->
        <Border Background="#1E1E1E" CornerRadius="8" Padding="20" BorderBrush="#333333" BorderThickness="1">
            <StackPanel Spacing="10">
                <TextBlock Text="System Diagnostics" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="Cyan"/>
                <TextBlock Text="CPU Usage: 14% (KreatorKlip AI)" FontFamily="Consolas"/>
                <TextBlock Text="GPU Usage (CUDA): 68% - 7.5GB / 12GB VRAM" FontFamily="Consolas"/>
                <TextBlock Text="Engine Status: IDLE" FontFamily="Consolas" Foreground="LimeGreen"/>
            </StackPanel>
        </Border>

        <!-- Pipeline Config -->
        <TextBlock Text="Backend Configuration" Style="{StaticResource TitleTextBlockStyle}" Margin="0,20,0,0"/>

        <StackPanel Spacing="8">
            <TextBlock Text="Game Source Folder"/>
            <TextBox PlaceholderText="e.g. C:\Users\Videos\OBS\" />
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock Text="Face-cam Coordinates (x, y, w, h)" />
            <TextBox Text="0, 0, 350, 350" />
            <TextBlock Text="Set to empty or null if no facecam." Foreground="Gray" FontSize="12"/>
        </StackPanel>
        
        <StackPanel Spacing="8">
            <TextBlock Text="Hype Keywords (Comma separated)" />
            <TextBox Text="let's go, clutch, headshot, insane" />
        </StackPanel>

        <ToggleSwitch Header="Force CPU Encoding (Disable NVENC)" OffContent="Using NVIDIA GPU" OnContent="Using CPU only" />
        
        <Button Content="Save Configuration" Style="{StaticResource AccentButtonStyle}" Width="200" Margin="0,20,0,0"/>
    </StackPanel>
</Page>
