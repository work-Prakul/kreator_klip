<Page
    x:Class="KreatorKlipUI.Views.GalleryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="300" />
        </Grid.RowDefinitions>

        <!-- Main Workspace (Preview + Inspector) -->
        <Grid Grid.Row="0" ColumnDefinitions="*, 320">
            <!-- Preview Monitor -->
            <Grid Grid.Column="0" Background="{StaticResource AppBackgroundBrush}" Padding="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Background="{StaticResource SurfaceHighBrush}" CornerRadius="4" Padding="8,2">
                            <TextBlock Text="4K UHD" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentPurpleLightBrush}" />
                        </Border>
                        <TextBlock Text="sequence_main_v04.mp4" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" FontStyle="Italic" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="16" VerticalAlignment="Center">
                        <TextBlock Text="Fit: 42%" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                        <SymbolIcon Symbol="FullScreen" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Background="Black" CornerRadius="8" IsHitTestVisible="True">
                    <Grid>
                        <!-- Main Video Placeholder -->
                        <Image Source="https://images.unsplash.com/photo-1542332213-9b5a5a3fad35?q=80&amp;w=2070&amp;auto=format&amp;fit=crop" Stretch="UniformToFill" Opacity="0.5" />
                        
                        <!-- 9:16 Smart Crop Overlay -->
                        <Border BorderBrush="{StaticResource AccentPurpleBrush}" BorderThickness="2" Width="200" HorizontalAlignment="Center" Margin="20">
                            <Border.Background>
                                <SolidColorBrush Color="White" Opacity="0.05" />
                            </Border.Background>
                        </Border>

                        <!-- Transport Controls (Floating Glass) -->
                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,24" 
                                Background="{StaticResource SurfaceLowBrush}" Opacity="0.9" CornerRadius="32" Padding="24,8">
                            <StackPanel Orientation="Horizontal" Spacing="24">
                                <SymbolIcon Symbol="Previous" Foreground="{StaticResource TextPrimaryBrush}" />
                                <SymbolIcon Symbol="Play" Foreground="{StaticResource AccentPurpleBrush}" />
                                <SymbolIcon Symbol="Next" Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Inspector Panel -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceLowBrush}" Padding="24">
                <StackPanel Spacing="32">
                    <TextBlock Text="Clip Properties" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource AccentPurpleBrush}" />
                    
                    <!-- Transform -->
                    <StackPanel Spacing="16">
                        <TextBlock Text="TRANSFORM" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" CharacterSpacing="100" />
                        
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Text="Scale" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1" Text="100.0%" FontSize="10" Foreground="{StaticResource AccentPurpleBrush}" />
                        </Grid>
                        <ProgressBar Value="100" />

                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Text="Opacity" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1" Text="85%" FontSize="10" Foreground="{StaticResource AccentPurpleBrush}" />
                        </Grid>
                        <ProgressBar Value="85" />
                    </StackPanel>

                    <Border Height="1" Background="{StaticResource SurfaceHighBrush}" Opacity="0.3" />

                    <!-- Audio Levels -->
                    <StackPanel Spacing="16">
                        <TextBlock Text="AUDIO LEVELS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" CharacterSpacing="100" />
                        <Grid Height="80" Background="{StaticResource AppBackgroundBrush}" CornerRadius="4" Padding="8">
                            <!-- Mock Visualization -->
                            <Rectangle Fill="{StaticResource Secondary}" Height="40" VerticalAlignment="Bottom" Margin="2" />
                        </Grid>
                        <TextBlock Text="-6.2 dB" FontSize="10" Foreground="{StaticResource Secondary}" HorizontalAlignment="Right" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Divider -->
        <Border Grid.Row="1" Height="2" Background="{StaticResource SurfaceHighBrush}" />

        <!-- Timeline -->
        <Grid Grid.Row="2" Background="{StaticResource SurfaceLowBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Ruler -->
            <Grid Grid.Row="0" Background="{StaticResource SurfaceHighBrush}" Opacity="0.5" Padding="12,0">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="00:04:12:15" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentPurpleBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="/ 00:12:00:00" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- Tracks -->
            <ScrollViewer Grid.Row="1">
                <StackPanel>
                    <!-- Video Track -->
                    <Grid Height="60" BorderBrush="{StaticResource SurfaceHighBrush}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource AppBackgroundBrush}" Padding="16,0">
                            <TextBlock Text="Video 1" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Border>
                        <Canvas Grid.Column="1">
                            <Border Canvas.Left="100" Width="400" Height="40" Margin="0,10" Background="{StaticResource SurfaceHighBrush}" BorderBrush="{StaticResource AccentPurpleBrush}" BorderThickness="2" CornerRadius="4">
                                <TextBlock Text="main_scene_v04.mp4" VerticalAlignment="Center" Margin="12,0" FontSize="10" Foreground="{StaticResource TextPrimaryBrush}" />
                            </Border>
                        </Canvas>
                    </Grid>
                    <!-- Audio Track -->
                    <Grid Height="60">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource AppBackgroundBrush}" Padding="16,0">
                            <TextBlock Text="Audio 1" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Border>
                        <Canvas Grid.Column="1">
                            <Border Canvas.Left="100" Width="800" Height="40" Margin="0,10" Background="{StaticResource Secondary}" Opacity="0.1" CornerRadius="4" />
                            <TextBlock Canvas.Left="112" Text="background_score.wav" VerticalAlignment="Center" Margin="0,20" FontSize="10" Foreground="{StaticResource Secondary}" />
                        </Canvas>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Playhead -->
            <Rectangle Grid.Row="1" Width="2" Fill="{StaticResource AccentPurpleBrush}" HorizontalAlignment="Left" Margin="250,0,0,0">
                <Rectangle.Shadow>
                    <ThemeShadow />
                </Rectangle.Shadow>
            </Rectangle>
        </Grid>
    </Grid>
</Page>
