<Application
    x:Class="KreatorKlipUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Digital Obsidian Color Palette (Purple Accent) -->
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#121315" />
            <SolidColorBrush x:Key="SurfaceLowBrush" Color="#1B1C1D" />
            <SolidColorBrush x:Key="SurfaceHighBrush" Color="#292A2B" />
            <SolidColorBrush x:Key="SurfaceHighestBrush" Color="#343536" />
            
            <SolidColorBrush x:Key="AccentPurpleBrush" Color="#7C3AED" />
            <SolidColorBrush x:Key="AccentPurpleLightBrush" Color="#9D5FFB" />
            <SolidColorBrush x:Key="OnAccentBrush" Color="White" />
            
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E5EFFF" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A1A1A1" />

            <!-- Global Style Overrides -->
            <Style TargetType="NavigationView">
                <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
                <Setter Property="PaneBackground" Value="{StaticResource SurfaceLowBrush}" />
            </Style>

            <Style x:Key="PremiumCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource SurfaceLowBrush}" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <Style TargetType="ProgressBar">
                <Setter Property="Background" Value="{StaticResource SurfaceHighestBrush}" />
                <Setter Property="Foreground" Value="{StaticResource AccentPurpleBrush}" />
                <Setter Property="Height" Value="2" />
                <Setter Property="VerticalAlignment" Value="Bottom" />
            </Style>

            <Style x:Key="AccentButtonPremium" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                <Setter Property="Background" Value="{StaticResource AccentPurpleBrush}" />
                <Setter Property="Foreground" Value="{StaticResource OnAccentBrush}" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="16,8" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
